# ── Google Gemini (Worker Agent — single LLM) ───────────
GEMINI_API_KEY=your_gemini_api_key

# ── Supabase (audit log database) ──────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── AgentBridge API ────────────────────────────────────
BACKEND_URL=http://localhost:8000
AGENTBRIDGE_API_KEY=test123

# ── Dev / dashboard demo ─────────────────────────────
# If the UI uses demo_key_001, set this on Render to match (or insert the key in Supabase api_keys):
# DEV_API_KEY=demo_key_001

# ── Optional: Groq (NL query / intelligence only) ──────
GROQ_API_KEY=

RATE_LIMIT_PER_MINUTE=60
ENV=production
